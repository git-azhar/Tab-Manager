{
  "manifest_version": 3,
  "name": "Tab Manager Pro",
  "version": "3.3.0",
  "description": "Advanced tab auto-close with multi-URL rules, memory & cache management, schedules, snooze, and analytics.",
  "permissions": [
    "tabs",
    "alarms",
    "notifications",
    "storage",
    "idle",
    "tabGroups",
    "browsingData",
    "scripting"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}